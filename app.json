          "backgroundColor": "#F5F3FF",
          "barStyle": "dark-content"
        }
      },
      "edgeToEdgeEnabled": true,
      "package": "com.chan.dev.cozydo"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "b6aee50b-343f-4bbd-92f4-42afebd580b3"
      }
    }
  }
}
